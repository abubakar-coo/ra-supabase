{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "dom"],
        "outDir": "lib",
        "rootDir": "src",
        "declaration": true,
        "declarationMap": true,
        "allowJs": false,
        "strictNullChecks": true
    },
    "exclude": ["**/*.spec.ts", "**/*.spec.tsx", "**/*.spec.js"],
    "include": ["src"]
}
